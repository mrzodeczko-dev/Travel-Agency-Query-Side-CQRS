
# ----------------------------------------------------------------------------------------------------------------------
# TRAVEL AGENCY QUERY SIDE - MONGODB
# ----------------------------------------------------------------------------------------------------------------------

MONGO_HOST=mongodb
MONGO_PORT=27018
MONGO_DB_NAME=travels_read_db
MONGO_USER=user
MONGO_PASSWORD=user1234

# ----------------------------------------------------------------------------------------------------------------------
# TRAVEL AGENCY QUERY SIDE - APPLICATION
# ----------------------------------------------------------------------------------------------------------------------

QUERY_SIDE_SERVICE_PORT=8081
QUERY_SIDE_SERVICE_APPLICATION_NAME=travel-agency-query-side

QUERY_SIDE_DEFAULT_HOTEL_CAPACITY=100
QUERY_SIDE_LAST_ROOMS_THRESHOLD=0.9

TOPIC_BOOKINGS=travel.bookings
TOPIC_AVAILABILITY=travel.availability
TOPIC_HOTELS=travel.hotels
TOPIC_HOTELS_DLT=travel.hotels.DLT
TOPIC_AVAILABILITY_DLT=travel.availability.DLT

# ----------------------------------------------------------------------------------------------------------------------
# KAFKA
# ----------------------------------------------------------------------------------------------------------------------
CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
# KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_BROKER_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_NODE_ID=1
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093
KAFKA_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092
KAFKA_LOG_DIRS=/var/lib/kafka/data
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_MIN_INSYNC_REPLICAS=1

KAFKA_HEAP_OPTS=-Xmx512M -Xms512M

ALLOW_PLAINTEXT_LISTENER=yes

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8200
KAFKA_STREAMS_APPLICATION_ID=travel-agency-query-side-streams
KAFKA_STREAMS_THREADS=3
KAFKA_STREAMS_STATE_DIR=/var/lib/travel-agency-query-side/kafka-streams
KAFKA_PROJECTION_GROUP_ID=travel-agency-query-side-projection
HOTELS_CONSUMER_GROUP=travel-agency-query-side-hotels